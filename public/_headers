# Expanded CSP for GTM proxy + all marketing tool scripts (2026-04-26)

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.googletagmanager.com https://thompsoncollective.co https://*.clarity.ms https://*.hs-scripts.com https://*.hs-analytics.net https://*.hscollectedforms.net https://*.hsadspixel.net https://*.hs-banner.com https://*.doubleclick.net https://*.google-analytics.com https://*.google.com https://*.facebook.net https://*.bing.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.doubleclick.net https://*.google.com https://*.clarity.ms https://*.bing.com https://*.hubspot.com https://*.hs-analytics.net https://*.hscollectedforms.net https://*.hsadspixel.net https://*.hs-banner.com https://*.facebook.net; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; frame-src 'self' https://*.googletagmanager.com https://thompsoncollective.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Cache-Control: public, max-age=86400, s-maxage=86400
  Content-Type: application/xml

/robots.txt
  Cache-Control: public, max-age=86400, s-maxage=86400

